# SES Think Tank — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── ENCRYPTION ──────────────────────────────────────────────────────────────
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this, encrypted API keys are lost on restart
SES_ENCRYPTION_KEY=

# ─── DEFAULT LLM PROVIDER ───────────────────────────────────────────────────
# Options: lm_studio, gemini, openai, anthropic, openrouter
SES_DEFAULT_PROVIDER=lm_studio

# ─── LM STUDIO (Local) ──────────────────────────────────────────────────────
LM_STUDIO_URL=http://localhost:1234
MODEL_ID=qwen/qwen3.6-27b

# ─── CLOUD PROVIDER API KEYS ────────────────────────────────────────────────
# Set these for cloud providers, or add them via the Settings UI after launch
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ─── TOOL INTEGRATIONS ──────────────────────────────────────────────────────
TAVILY_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=

# ─── DATABASE PATHS ─────────────────────────────────────────────────────────
SES_MEMORY_DB=data/memory.db
SES_SETTINGS_DB=data/settings.db

# ─── SERVER ─────────────────────────────────────────────────────────────────
PORT=8773
HOST=0.0.0.0
